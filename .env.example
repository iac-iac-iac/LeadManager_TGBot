# Telegram Bot
# Получить токен: https://t.me/BotFather
TELEGRAM_BOT_TOKEN=YOUR_TELEGRAM_BOT_TOKEN_HERE

# Bitrix24 Webhook
# Создать вебхук: https://your-portal.bitrix24.ru/marketplace/hookbot/
BITRIX24_WEBHOOK_URL=https://YOUR_PORTAL.bitrix24.ru/rest/YOUR_WEBHOOK_ID/

# Database
DATABASE_PATH=./data/leads.db

# Uploads Folder
UPLOADS_FOLDER=./uploads

# Admin Telegram IDs (список админов через запятую)
# Узнать свой ID: https://t.me/userinfobot
ADMIN_TELEGRAM_IDS=YOUR_ADMIN_TELEGRAM_ID

# Logging
LOG_LEVEL=INFO
LOG_FILE=./logs/bot.log

# Proxy (опционально, для работы в РФ)
# TELEGRAM_PROXY_URL=http://proxy-server:port
# TELEGRAM_PROXY_TYPE=HTTP  # HTTP или SOCKS5

# Bitrix24 Proxy (опционально)
# BITRIX24_PROXY_URL=http://proxy-server:port
